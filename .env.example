# Copy to .env and fill in your values

# Secret used to sign session cookies (any long random string)
SECRET_KEY=change-me-to-a-long-random-string

# Google OAuth credentials
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# The PI (admin) is identified by email. First user with this email becomes admin.
# You can add more admins later via the admin UI.
PI_EMAIL=pi@yourlab.edu

# Admin-only login at /admin/login uses this password. Leave empty to disable
# password-based admin login (Google login still works for the PI_EMAIL account).
ADMIN_PASSWORD=

# Restrict signups to specific email domains (comma separated). Leave blank to allow any.
ALLOWED_EMAIL_DOMAINS=

# Default GPU hours granted to new users (PI can adjust per user)
DEFAULT_QUOTA_HOURS=40

# SMTP for outbound email notifications.
# For Gmail, use an "App Password": https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=GPU Manager <noreply@yourlab.edu>

# Set to false to disable email sending (useful for local testing)
EMAIL_ENABLED=true

# How long (minutes) the next-in-queue user has to confirm before being skipped
QUEUE_CONFIRM_MINUTES=15

# Max single reservation length in hours (sanity cap)
MAX_RESERVATION_HOURS=24

# Send a "your session ends soon" email this many minutes before expected end
WARN_BEFORE_END_MINUTES=15

# Base URL of the app (used in emails for clickable links)
BASE_URL=http://localhost:8000
